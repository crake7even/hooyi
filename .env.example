# Backend-only secrets. Do not expose these with VITE_ prefixes.
TMDB_READ_TOKEN="YOUR_TMDB_READ_ACCESS_TOKEN"
TMDB_API_KEY="YOUR_TMDB_API_KEY"
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"

# Optional backend settings.
PORT="3001"
TMDB_WATCH_REGIONS="CN,US"
DEEPSEEK_MODEL="deepseek-chat"
CORS_ORIGINS="http://localhost:3000,https://YOUR_NETLIFY_SITE.netlify.app"

# Optional. Set this if Node cannot reach TMDB/DeepSeek directly but your browser can through a local proxy.
API_PROXY_URL="http://127.0.0.1:7897"

# Public frontend API entrypoint.
VITE_API_BASE_URL="http://localhost:3001"

# Netlify production example:
# VITE_API_BASE_URL="https://YOUR_BACKEND_DOMAIN"
