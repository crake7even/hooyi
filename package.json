{
  "name": "hooyi",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "description": "AI-assisted movie discovery with TMDB catalog data, mood-based recommendations, watch providers, and optional Supabase sync.",
  "keywords": [
    "movie-discovery",
    "react",
    "tmdb",
    "deepseek",
    "supabase"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/crake7even/hooyi.git"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "api": "tsx server.ts",
    "start": "node server.js",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --outfile=server.js --packages=external",
    "build:all": "npm run build && npm run build:server",
    "preview": "vite preview",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('server.js',{force:true})\"",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "tsx --test tests/*.test.ts",
    "sanitize:cache": "tsx scripts/sanitize-cache.ts",
    "check": "npm run typecheck && npm run test && npm run build:all"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "~5.8.2",
    "vite": "^6.4.3"
  }
}
